#!/usr/bin/env node
'use strict';

const fs = require("fs");
const path = require("path");
const probe = require("probe-image-size");

const Dex = require('./../caches/BudewInn-Showdown-Server/dist/sim/dex').Dex;
const toID = Dex.toID;

const SPRITES_BASE = "https://budewinn.it/sprites";
const CACHE_FILE = path.resolve(__dirname, 'cache-sizes.json');

let buf = `/*
DO NOT EDIT

THIS FILE IS AUTOGENERATED BY ./build-tools/build-minidex-remote
*/

exports.BattlePokemonSprites = {
\tsubstitute:{exists:false, front:{w:34, h:39}, back:{w:37, h:38}},
`;

let g5buf = `/*
DO NOT EDIT

THIS FILE IS AUTOGENERATED BY ./build-tools/build-minidex-remote
*/

exports.BattlePokemonSpritesBW = {
`;

let cache = {};
if (fs.existsSync(CACHE_FILE)) {
	try {
		cache = JSON.parse(fs.readFileSync(CACHE_FILE, 'utf8'));
	} catch { }
}

function saveCache() {
	fs.writeFileSync(CACHE_FILE, JSON.stringify(cache, null, 2));
}

// fetch remoto con cache
async function remoteSize(url, cacheKey) {
	if (cache[cacheKey]) return cache[cacheKey];
	try {
		const result = await probe(url);
		const size = { w: result.width, h: result.height };
		cache[cacheKey] = size;
		return size;
	} catch {
		return null;
	}
}

// batch helper
async function runBatched(tasks, batchSize = 10) {
	const results = [];
	for (let i = 0; i < tasks.length; i += batchSize) {
		const batch = tasks.slice(i, i + batchSize).map(fn => fn());
		const res = await Promise.all(batch);
		results.push(...res);
		const percent = Math.min(100, Math.round((i + batch.length) / tasks.length * 100));
		process.stdout.write(`\rProgress: ${percent}% (${i + batch.length}/${tasks.length})`);
	}
	console.log();
	return results;
}

async function updateSizes() {
	const tasks = [];

	for (const baseid in Dex.data.Pokedex) {
		const species = Dex.species.get(baseid);
		for (const formeName of [''].concat(species.cosmeticFormes || [])) {
			let spriteid = species.spriteid;
			if (formeName) spriteid += '-' + toID(formeName).slice(species.id.length);
			const id = toID(spriteid);

			// animated
			tasks.push(async () => {
				const row = { num: species.num };
				const frontSize = await remoteSize(`${SPRITES_BASE}/ani/${spriteid}.gif`, `${id}-front`);
				if (frontSize) row.front = frontSize;
				const frontSizeF = await remoteSize(`${SPRITES_BASE}/ani/${spriteid}-f.gif`, `${id}-frontf`);
				if (frontSizeF) row.frontf = frontSizeF;
				const backSize = await remoteSize(`${SPRITES_BASE}/ani-back/${spriteid}.gif`, `${id}-back`);
				if (backSize) row.back = backSize;
				const backSizeF = await remoteSize(`${SPRITES_BASE}/ani-back/${spriteid}-f.gif`, `${id}-backf`);
				if (backSizeF) row.backf = backSizeF;
				if (row.front || row.back || !row.forme) {
					buf += `\t${id}:` + JSON.stringify(row).replace(/"/g, '') + `,\n`;
				}
				return true;
			});

			// gen5
			tasks.push(async () => {
				const g5row = { num: species.num };
				const frontSize = await remoteSize(`${SPRITES_BASE}/gen5ani/${spriteid}.gif`, `${id}-g5front`);
				if (frontSize) g5row.front = frontSize;
				const frontSizeF = await remoteSize(`${SPRITES_BASE}/gen5ani/${spriteid}-f.gif`, `${id}-g5frontf`);
				if (frontSizeF) g5row.frontf = frontSizeF;
				const backSize = await remoteSize(`${SPRITES_BASE}/gen5ani-back/${spriteid}.gif`, `${id}-g5back`);
				if (backSize) g5row.back = backSize;
				const backSizeF = await remoteSize(`${SPRITES_BASE}/gen5ani-back/${spriteid}-f.gif`, `${id}-g5backf`);
				if (backSizeF) g5row.backf = backSizeF;
				if (g5row.front || g5row.back || !g5row.forme) {
					g5buf += `\t${id}:` + JSON.stringify(g5row).replace(/"/g, '') + `,\n`;
				}
				return true;
			});
		}
	}

	await runBatched(tasks, 10);
	saveCache();

	buf = buf.slice(0, -2) + `\n};\n`;
	g5buf = g5buf.slice(0, -2) + `\n};\n`;

	fs.writeFileSync('../play.pokemonshowdown.com/data/pokedex-mini.js', buf);
	fs.writeFileSync('../play.pokemonshowdown.com/data/pokedex-mini-bw.js', g5buf);
}

(async () => {
	console.log("Updating animated sprite dimensions (remote)...");
	await updateSizes();
	console.log("DONE");
})();
